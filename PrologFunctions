% Question 4 - (10 points) Define emptyInt to return true if the intersection of two lists is empty.
% Below are two base cases for question 4, followed by the stub of a rule. Uncomment and complete the stub.
emptyInt([],[]). % This base case says that the intersection is empty if both lists are empty
emptyInt([],_). % This base cases says that the intersection is empty if the first list is empty
emptyInt([H | T], L) :- \+ (member(H, L); (member(X, T), member(X, L))). % negate: the first element in the first list is in the second or there is an element in T which is also in L
% intersection has just common elements, no duplicates


% Question 5 - (10 points) Define listUnion(UL, L1, L2) as "UL is the union of L1 and L2".
% things in any list, no duplicates
listUnion([], [], []). % base case: if all empty, then good
listUnion(U1, L1, L2) :-
    append(L1, L2, Union), % combine L1 and L2
    sort(Union, UnionSorted), % sort the combo of L1 and L2
    sort(U1, U1Sorted), % sort the given union
    U1Sorted = UnionSorted, % compare expected union with the sorted combo of L1 and L2
    is_set(U1). % don't allow duplicates in the given union
    
% Question 6 - (10 points) Define finalElement(X, L) as "X is the final element of the list L".
finalElement(_, []) :- false.% if list is empty, not good
finalElement(X, L) :- reverse(L, ReversedL), ReversedL = [Last | _], X = Last. % reverse the list, then see if its head is X
